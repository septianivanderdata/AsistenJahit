# === Telegram ===
TELEGRAM_BOT_TOKEN=isi_token_dari_@BotFather

# === Google Gemini (free tier via Google AI Studio) ===
# Ambil key gratis di https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxx
# Model ekstraksi & narasi (gratis+cepat).
GEMINI_MODEL=gemini-3.5-flash

# === Supabase ===
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=service_role_key_rahasia
SUPABASE_ANON_KEY=anon_key_untuk_dashboard

# === Dashboard ===
# Token rahasia untuk akses dashboard read-only (query param ?token=...)
DASHBOARD_TOKEN=ganti_dengan_string_acak_panjang

# === App ===
# Ambang margin oper dianggap layak (persen). Default 20.
MARGIN_THRESHOLD_PCT=20
TZ=Asia/Jakarta

# === Dashboard base URL (dipakai perintah /dashboard di bot) ===
# Lokal: http://127.0.0.1:5173/index.html — produksi: URL halaman dashboard yang dideploy
DASHBOARD_BASE_URL=http://127.0.0.1:5173/index.html
